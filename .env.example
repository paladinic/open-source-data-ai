# ── LLM provider ──────────────────────────────────────────────────────────────
# Pick one provider and set the matching key + model below.

# Anthropic (default)
# ANTHROPIC_API_KEY=your-key-here

# OpenAI
# OPENAI_API_KEY=your-key-here

# Google Gemini
# GEMINI_API_KEY=your-key-here

LLM_PROVIDER=gemini          # anthropic | openai | gemini
LLM_MODEL=gemini-1.5-flash   # gemini-1.5-flash | gemini-1.5-pro | claude-sonnet-4-6 | gpt-4o

# Local storage path (relative to backend/)
DATA_DIR=../data

# ── Supabase ───────────────────────────────────────────────────────────────────
# Required for user auth and the admin bootstrap flow.
# Find these in your Supabase project → Settings → API.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
